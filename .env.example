# Application
ENVIRONMENT=production
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost

# Database
DATABASE_URL=sqlite+aiosqlite:////data/security_dashboard.db
REDIS_URL=redis://redis:6379/0

# AWS (EC2 instance role recommended; keys optional)
AWS_REGION=ap-south-1
AWS_DELEGATED_ACCOUNT_ID=
AWS_ORGANIZATION_ID=
SECURITY_HUB_ADMIN_ACCOUNT_ID=
INSPECTOR_AGGREGATION_REGION=ap-south-1
S3_FINDINGS_BUCKET=
S3_FINDINGS_PREFIX=findings-count/
CSPM_SCORES_S3_URL=

# Azure AD / Microsoft Graph (email)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=AWS Security Dashboard

# Auth
AZURE_AD_AUDIENCE=
JWT_SECRET=change-me-in-production-use-long-random-string

# Scheduling
SCHEDULER_TIMEZONE=UTC
DEFAULT_SCHEDULE_CRON=0 6 * * 1

# Reports
REPORTS_OUTPUT_DIR=/tmp/reports
CHARTS_OUTPUT_DIR=/tmp/charts
